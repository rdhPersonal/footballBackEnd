{
  "name": "football-backend",
  "version": "0.1.0",
  "private": true,
  "description": "AWS backend for NFL player statistics — Lambda, API Gateway, RDS PostgreSQL",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "migrate": "tsx scripts/migrate.ts",
    "backfill": "tsx scripts/backfill.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "load-season": "tsx scripts/load-season.ts",
    "clear-season": "tsx scripts/clear-season.ts"
  },
  "dependencies": {
    "@aws-sdk/client-rds": "^3.909.0",
    "@aws-sdk/client-secrets-manager": "^3.909.0",

    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
