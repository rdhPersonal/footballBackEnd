# Copy this file to dev.secret.tfvars for local-only Terraform overrides.
# dev.secret.tfvars is gitignored -- NEVER commit it.
#
# The database password is now managed by RDS in AWS Secrets Manager, so no
# TF_VAR_db_password value is needed.
#
# Example:
#   export TF_VAR_bastion_ssh_cidr="$(curl -s4 ifconfig.me)/32"

bastion_ssh_cidr = "YOUR_PUBLIC_IP/32"   # e.g. "203.0.113.42/32"
