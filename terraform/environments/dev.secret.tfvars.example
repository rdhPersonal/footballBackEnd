# Copy this file to dev.secret.tfvars and fill in real values.
# dev.secret.tfvars is gitignored -- NEVER commit it.
#
# Alternatively, set these as environment variables:
#   export TF_VAR_bastion_ssh_cidr="$(curl -s4 ifconfig.me)/32"
#   export TF_VAR_db_password="your-password-here"

bastion_ssh_cidr = "YOUR_PUBLIC_IP/32"   # e.g. "203.0.113.42/32"
db_password      = "CHANGE_ME"
